# Professional Portfolio environment — copy to .env and adjust. NEVER commit your real .env.
#
#   cp .env.example .env      (PowerShell: Copy-Item .env.example .env)
#
# There are NO secrets here — this is a static site. These values only control how the
# Docker container's port is published on your machine.

# Host address the container's port is published to.
#   127.0.0.1  -> localhost only (default, most private)
#   0.0.0.0    -> reachable from other devices on your Wi-Fi and over Tailscale
# Set this to 0.0.0.0 only when you deliberately want LAN/Tailscale access.
BIND_ADDR=127.0.0.1

# Host port to serve on (the in-container port is always 8790).
PORT=8790

# --- Ask Fredrik widget (optional, build-time) ---
# Full /ask endpoint URL of the answer API (cloudflare/ask-fredrik-worker — see
# its README for local dev and deploy). Leave unset for the free static v1 —
# the widget then uses its curated built-in answers.
# This is a PUBLIC url baked into the JS bundle, never an API key.
# VITE_ASK_FREDRIK_API_URL=http://localhost:8787/ask

# --- Ask Fredrik admin dashboard (local dev only, build-time) ---
# Worker origin the admin panel (/admin/ask-fredrik/) calls during `npm run dev`.
# In production the Worker serves the panel itself (same origin, Cloudflare
# Access) — see docs/ask-fredrik-dashboard.md. PUBLIC url, never a secret.
# VITE_ASK_FREDRIK_ADMIN_URL=http://127.0.0.1:8787
